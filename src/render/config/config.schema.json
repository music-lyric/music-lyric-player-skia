        },
        {
          "name": "scroll",
          "nested": "scroll.Root",
          "desc": [
            "Viewport scrolling and transition animation."
          ]
        },
        {
          "name": "line",
          "nested": "line.Root",
          "desc": [
            "Lyric line rendering: shared font and per-state colors."
          ]
        }
      ]
    }
  ]
