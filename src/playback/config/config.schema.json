        { "name": "mergeWindow", "type": "double", "default": "300.0", "comment": "ms cluster for joint deactivation" },
        { "name": "mergeLimit", "type": "int", "default": "3", "comment": "max lines per merge batch" },
        { "name": "offset", "nested": "OffsetConfig", "comment": "the three-layer offset's global settings" }
