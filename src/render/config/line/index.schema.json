{
  "namespace": "music_lyric_player::render::config::line",
  "file": "index.gen.h",
  "imports": [
    { "as": "common", "schema": "../common/index.schema.json" },
    { "as": "interlude", "schema": "interlude/index.schema.json" }
  ],
  "items": [
    {
      "name": "Root",
      "comment": "Font, state colors, and instrumental-gap indicators of lyric lines.",
      "fields": [
        {
          "name": "font",
          "nested": "common.FontConfig",
          "comment": "Font shared by every line."
        },
        {
          "name": "normal",
          "nested": "common.StyleConfig",
          "defaults": {
            "color": "\"rgba(255, 255, 255, 0.4)\""
          },
          "comment": "Style of inactive lines (default color `rgba(255, 255, 255, 0.4)`)."
        },
        {
          "name": "active",
          "nested": "common.StyleConfig",
          "defaults": {
            "color": "\"#ffffff\""
          },
          "comment": "Style of the active line (default color `#ffffff`)."
        },
        {
          "name": "interlude",
          "nested": "interlude.Root",
          "comment": "Instrumental-gap indicator geometry and animation styles."
        }
      ]
    }
  ]
}
