        { "name": "bridgeActive", "type": "bool", "default": "true", "desc": "fill active-index gaps" },
        { "name": "mergeWindow", "type": "double", "default": "300.0", "desc": "ms cluster for joint deactivation" },
        { "name": "mergeLimit", "type": "int", "default": "3", "desc": "max lines per merge batch" },
        { "name": "offset", "nested": "OffsetConfig", "desc": "the three-layer offset's global settings" }
