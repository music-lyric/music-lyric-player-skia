  "imports": [
    { "as": "container", "schema": "container/index.schema.json" },
    { "as": "layout", "schema": "layout/index.schema.json" },
    { "as": "scroll", "schema": "scroll/index.schema.json" },
    { "as": "line", "schema": "line/index.schema.json" }
  ],
  "items": [
